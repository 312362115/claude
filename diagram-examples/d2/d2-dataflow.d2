# 数据流图 — ETL 数据管道

direction: right

# --- 数据源 ---
sources: 数据源 {
  style: { fill: "#EFF6FF"; stroke: "#BFDBFE"; border-radius: 8; font-color: "#1E40AF"; font-size: 13; bold: true }

  mysql: 业务数据库 {
    shape: cylinder
    style: { fill: "#FFFFFF"; stroke: "#3B82F6"; font-color: "#1E293B"; font-size: 12 }
  }
  api: 第三方 API {
    style: { fill: "#FFFFFF"; stroke: "#3B82F6"; font-color: "#1E293B"; border-radius: 6; font-size: 12 }
  }
  log: 应用日志 {
    style: { fill: "#FFFFFF"; stroke: "#3B82F6"; font-color: "#1E293B"; border-radius: 6; font-size: 12 }
  }
}

# --- 采集 ---
collect: 数据采集 {
  style: { fill: "#ECFDF5"; stroke: "#A7F3D0"; border-radius: 8; font-color: "#065F46"; font-size: 13; bold: true }

  kafka: Kafka {
    style: { fill: "#FFFFFF"; stroke: "#10B981"; font-color: "#065F46"; border-radius: 6; font-size: 12 }
  }
  flink: Flink CDC {
    style: { fill: "#FFFFFF"; stroke: "#10B981"; font-color: "#065F46"; border-radius: 6; font-size: 12 }
  }
}

# --- 处理 ---
process: 数据处理 {
  style: { fill: "#FFFBEB"; stroke: "#FDE68A"; border-radius: 8; font-color: "#92400E"; font-size: 13; bold: true }

  clean: 清洗转换 {
    style: { fill: "#FFFFFF"; stroke: "#F59E0B"; font-color: "#92400E"; border-radius: 6; font-size: 12 }
  }
  agg: 聚合计算 {
    style: { fill: "#FFFFFF"; stroke: "#F59E0B"; font-color: "#92400E"; border-radius: 6; font-size: 12 }
  }
}

# --- 存储 ---
store: 数据存储 {
  style: { fill: "#F5F3FF"; stroke: "#8B5CF6"; border-radius: 8; font-color: "#5B21B6"; font-size: 13; bold: true }

  dw: 数据仓库 {
    shape: cylinder
    style: { fill: "#FFFFFF"; stroke: "#8B5CF6"; font-color: "#5B21B6"; font-size: 12 }
  }
  es: Elasticsearch {
    shape: cylinder
    style: { fill: "#FFFFFF"; stroke: "#8B5CF6"; font-color: "#5B21B6"; font-size: 12 }
  }
}

# --- 输出 ---
output: 数据消费 {
  style: { fill: "#ECFEFF"; stroke: "#A5F3FC"; border-radius: 8; font-color: "#155E75"; font-size: 13; bold: true }

  bi: BI 报表 {
    style: { fill: "#FFFFFF"; stroke: "#06B6D4"; font-color: "#155E75"; border-radius: 6; font-size: 12 }
  }
  api-out: 数据 API {
    style: { fill: "#FFFFFF"; stroke: "#06B6D4"; font-color: "#155E75"; border-radius: 6; font-size: 12 }
  }
}

# --- 连线 ---
sources.mysql -> collect.flink: Binlog { style.stroke: "#94A3B8"; style.font-color: "#64748B"; style.font-size: 10 }
sources.api -> collect.kafka { style.stroke: "#94A3B8" }
sources.log -> collect.kafka { style.stroke: "#94A3B8" }

collect.kafka -> process.clean { style.stroke: "#94A3B8" }
collect.flink -> process.clean { style.stroke: "#94A3B8" }

process.clean -> process.agg { style.stroke: "#94A3B8" }

process.agg -> store.dw { style.stroke: "#94A3B8" }
process.agg -> store.es { style.stroke: "#94A3B8" }

store.dw -> output.bi { style.stroke: "#94A3B8" }
store.es -> output.api-out { style.stroke: "#94A3B8" }
