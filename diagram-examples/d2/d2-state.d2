# 订单状态机

direction: right

# ============ 状态节点 ============

initial: "" {
  shape: circle
  width: 30
  height: 30
  style: {
    fill: "#37474f"
    stroke: "#263238"
  }
}

pending-payment: 待支付 {
  style: {
    fill: "#fff3e0"
    stroke: "#ffa726"
    font-color: "#e65100"
    border-radius: 10
    shadow: true
  }
}

paid: 已支付 {
  style: {
    fill: "#e3f2fd"
    stroke: "#42a5f5"
    font-color: "#1565c0"
    border-radius: 10
    shadow: true
  }
}

preparing: 备货中 {
  style: {
    fill: "#e3f2fd"
    stroke: "#42a5f5"
    font-color: "#1565c0"
    border-radius: 10
    shadow: true
  }
}

shipped: 已发货 {
  style: {
    fill: "#e8f5e9"
    stroke: "#66bb6a"
    font-color: "#2e7d32"
    border-radius: 10
    shadow: true
  }
}

delivered: 已签收 {
  style: {
    fill: "#e8f5e9"
    stroke: "#43a047"
    font-color: "#1b5e20"
    border-radius: 10
    shadow: true
  }
}

completed: 已完成 {
  style: {
    fill: "#c8e6c9"
    stroke: "#2e7d32"
    font-color: "#1b5e20"
    border-radius: 10
    shadow: true
  }
}

cancelled: 已取消 {
  style: {
    fill: "#ffebee"
    stroke: "#ef5350"
    font-color: "#c62828"
    border-radius: 10
    shadow: true
  }
}

refunding: 退款中 {
  style: {
    fill: "#fce4ec"
    stroke: "#ec407a"
    font-color: "#880e4f"
    border-radius: 10
    shadow: true
  }
}

refunded: 已退款 {
  style: {
    fill: "#f3e5f5"
    stroke: "#ab47bc"
    font-color: "#6a1b9a"
    border-radius: 10
    shadow: true
  }
}

closed: 已关闭 {
  style: {
    fill: "#eceff1"
    stroke: "#78909c"
    font-color: "#37474f"
    border-radius: 10
    shadow: true
  }
}

final: "" {
  shape: circle
  width: 36
  height: 36
  style: {
    fill: "#37474f"
    stroke: "#263238"
  }
}

# ============ 状态转换 ============

initial -> pending-payment: 创建订单 {
  style: { stroke: "#37474f"; font-color: "#37474f" }
}

pending-payment -> paid: 支付成功 {
  style: { stroke: "#42a5f5"; font-color: "#1565c0" }
}

pending-payment -> cancelled: 超时未支付 / 用户取消 {
  style: { stroke: "#ef5350"; font-color: "#c62828" }
}

paid -> preparing: 商家确认 {
  style: { stroke: "#42a5f5"; font-color: "#1565c0" }
}

paid -> refunding: 用户申请退款 {
  style: { stroke: "#ec407a"; font-color: "#880e4f" }
}

preparing -> shipped: 商家发货 {
  style: { stroke: "#66bb6a"; font-color: "#2e7d32" }
}

preparing -> refunding: 用户申请退款 {
  style: { stroke: "#ec407a"; font-color: "#880e4f" }
}

shipped -> delivered: 用户签收 / 自动签收 {
  style: { stroke: "#66bb6a"; font-color: "#2e7d32" }
}

shipped -> refunding: 拒收退回 {
  style: { stroke: "#ec407a"; font-color: "#880e4f" }
}

delivered -> completed: 确认收货 / 7天自动确认 {
  style: { stroke: "#2e7d32"; font-color: "#1b5e20" }
}

delivered -> refunding: 申请售后退款 {
  style: { stroke: "#ec407a"; font-color: "#880e4f" }
}

refunding -> refunded: 退款审核通过 {
  style: { stroke: "#ab47bc"; font-color: "#6a1b9a" }
}

refunding -> preparing: 退款审核拒绝（发货前） {
  style: { stroke: "#42a5f5"; font-color: "#1565c0"; stroke-dash: 5 }
}

refunding -> delivered: 退款审核拒绝（签收后） {
  style: { stroke: "#66bb6a"; font-color: "#2e7d32"; stroke-dash: 5 }
}

completed -> closed: 售后期结束 {
  style: { stroke: "#78909c"; font-color: "#546e7a" }
}

cancelled -> final {
  style: { stroke: "#78909c" }
}

refunded -> final {
  style: { stroke: "#78909c" }
}

closed -> final {
  style: { stroke: "#78909c" }
}
