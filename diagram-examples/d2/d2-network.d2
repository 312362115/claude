# 企业网络拓扑图

direction: down

# --- 外部 ---
internet: 互联网 {
  shape: cloud
  style: {
    fill: "#ECFEFF"
    stroke: "#06B6D4"
    font-color: "#155E75"
    font-size: 13
  }
}

# --- 边界 ---
firewall: 防火墙 {
  style: {
    fill: "#FFFFFF"
    stroke: "#FDA4AF"
    font-color: "#9F1239"
    border-radius: 6
    font-size: 13
  }
}

# --- DMZ ---
dmz: DMZ {
  style: {
    fill: "#FFFBEB"
    stroke: "#FDE68A"
    border-radius: 8
    font-color: "#92400E"
    font-size: 13
    bold: true
  }

  lb: 负载均衡 {
    style: { fill: "#FFFFFF"; stroke: "#FCD34D"; font-color: "#92400E"; border-radius: 6; font-size: 12 }
  }
  waf: WAF {
    style: { fill: "#FFFFFF"; stroke: "#FCD34D"; font-color: "#92400E"; border-radius: 6; font-size: 12 }
  }
  dns: DNS {
    style: { fill: "#FFFFFF"; stroke: "#FCD34D"; font-color: "#92400E"; border-radius: 6; font-size: 12 }
  }
}

# --- 内网-服务区 ---
servers: 服务器区 {
  style: {
    fill: "#ECFDF5"
    stroke: "#A7F3D0"
    border-radius: 8
    font-color: "#065F46"
    font-size: 13
    bold: true
  }

  app1: 应用服务器 {
    style: { fill: "#FFFFFF"; stroke: "#6EE7B7"; font-color: "#065F46"; border-radius: 6; font-size: 12 }
  }
  app2: API 服务器 {
    style: { fill: "#FFFFFF"; stroke: "#6EE7B7"; font-color: "#065F46"; border-radius: 6; font-size: 12 }
  }
  mq: 消息队列 {
    style: { fill: "#FFFFFF"; stroke: "#6EE7B7"; font-color: "#065F46"; border-radius: 6; font-size: 12 }
  }
}

# --- 内网-数据区 ---
data: 数据区 {
  style: {
    fill: "#F5F3FF"
    stroke: "#C4B5FD"
    border-radius: 8
    font-color: "#5B21B6"
    font-size: 13
    bold: true
  }

  db: MySQL 主从 {
    shape: cylinder
    style: { fill: "#FFFFFF"; stroke: "#C4B5FD"; font-color: "#5B21B6"; font-size: 12 }
  }
  redis: Redis 集群 {
    shape: cylinder
    style: { fill: "#FFFFFF"; stroke: "#C4B5FD"; font-color: "#5B21B6"; font-size: 12 }
  }
  es: Elasticsearch {
    shape: cylinder
    style: { fill: "#FFFFFF"; stroke: "#C4B5FD"; font-color: "#5B21B6"; font-size: 12 }
  }
}

# --- 连线 ---
internet -> firewall { style.stroke: "#94A3B8" }
firewall -> dmz.lb { style.stroke: "#94A3B8" }
dmz.lb -> dmz.waf { style.stroke: "#94A3B8" }
dmz.lb -> servers.app1 { style.stroke: "#94A3B8" }
dmz.lb -> servers.app2 { style.stroke: "#94A3B8" }
servers.app1 -> data.db { style.stroke: "#94A3B8" }
servers.app2 -> data.redis { style.stroke: "#94A3B8" }
servers.app1 -> servers.mq { style.stroke: "#94A3B8" }
servers.mq -> data.es { style.stroke: "#94A3B8"; style.stroke-dash: 3 }
