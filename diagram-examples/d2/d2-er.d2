# 电商数据库 ER 图

direction: right

# --- 核心表 ---
users: 用户表 users {
  shape: sql_table
  style: {
    fill: "#F8FAFC"
    stroke: "#93C5FD"
    font-color: "#1E293B"
    font-size: 13
  }
  id: INT {constraint: primary_key}
  username: VARCHAR(50)
  email: VARCHAR(100)
  phone: VARCHAR(20)
  status: ENUM
  created_at: TIMESTAMP
}

orders: 订单表 orders {
  shape: sql_table
  style: {
    fill: "#F8FAFC"
    stroke: "#93C5FD"
    font-color: "#1E293B"
    font-size: 13
  }
  id: INT {constraint: primary_key}
  user_id: INT {constraint: foreign_key}
  total_amount: DECIMAL
  status: ENUM
  created_at: TIMESTAMP
}

# --- 普通表 ---
products: 商品表 products {
  shape: sql_table
  style: {
    fill: "#F8FAFC"
    stroke: "#93C5FD"
    font-color: "#1E293B"
    font-size: 13
  }
  id: INT {constraint: primary_key}
  name: VARCHAR(200)
  price: DECIMAL
  stock: INT
  category_id: INT {constraint: foreign_key}
}

categories: 分类表 categories {
  shape: sql_table
  style: {
    fill: "#F8FAFC"
    stroke: "#93C5FD"
    font-color: "#1E293B"
    font-size: 13
  }
  id: INT {constraint: primary_key}
  name: VARCHAR(100)
  parent_id: INT
}

# --- 关联表 ---
order_items: 订单明细 order_items {
  shape: sql_table
  style: {
    fill: "#F8FAFC"
    stroke: "#CBD5E1"
    font-color: "#1E293B"
    font-size: 13
  }
  id: INT {constraint: primary_key}
  order_id: INT {constraint: foreign_key}
  product_id: INT {constraint: foreign_key}
  quantity: INT
  price: DECIMAL
}

payments: 支付记录 payments {
  shape: sql_table
  style: {
    fill: "#F8FAFC"
    stroke: "#CBD5E1"
    font-color: "#1E293B"
    font-size: 13
  }
  id: INT {constraint: primary_key}
  order_id: INT {constraint: foreign_key}
  amount: DECIMAL
  method: ENUM
  status: ENUM
  paid_at: TIMESTAMP
}

# --- 关系连线 ---
users -> orders: 1:N {
  style.stroke: "#94A3B8"
  style.font-color: "#64748B"
  style.font-size: 11
}
orders -> order_items: 1:N {
  style.stroke: "#94A3B8"
  style.font-color: "#64748B"
  style.font-size: 11
}
products -> order_items: 1:N {
  style.stroke: "#94A3B8"
  style.font-color: "#64748B"
  style.font-size: 11
}
categories -> products: 1:N {
  style.stroke: "#94A3B8"
  style.font-color: "#64748B"
  style.font-size: 11
}
orders -> payments: 1:N {
  style.stroke: "#94A3B8"
  style.font-color: "#64748B"
  style.font-size: 11
}
