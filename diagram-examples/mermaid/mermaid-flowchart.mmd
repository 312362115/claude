flowchart TD
    start([用户提交订单]):::termStart
    validate[订单参数校验]:::process
    isValid{参数合法?}:::decision
    checkStock[库存检查]:::process
    hasStock{库存充足?}:::decision
    lockStock[锁定库存]:::process
    createOrder[创建订单记录]:::highlight

    subgraph payment [支付处理]
        callPay[调用支付服务]:::process
        payOk{支付成功?}:::decision
    end

    confirm[确认订单]:::success
    notify[发送订单通知]:::process
    done([订单完成]):::termStart

    errInvalid[返回参数错误]:::error
    errStock[退回库存不足]:::error
    errPay[支付失败处理]:::error
    fail([订单失败]):::termEnd

    start --> validate
    validate --> isValid
    isValid -->|是| checkStock
    isValid -->|否| errInvalid
    checkStock --> hasStock
    hasStock -->|是| lockStock
    hasStock -->|否| errStock
    lockStock --> createOrder
    createOrder --> callPay
    callPay --> payOk
    payOk -->|是| confirm
    payOk -->|否| errPay
    confirm --> notify
    notify --> done

    errInvalid -.-> fail
    errStock -.-> fail
    errPay -.-> fail

    classDef termStart fill:#ECFDF5,stroke:#6EE7B7,stroke-width:1.5px,color:#065F46,rx:20
    classDef termEnd fill:#F1F5F9,stroke:#CBD5E1,stroke-width:1.5px,color:#64748B,rx:20
    classDef process fill:#EFF6FF,stroke:#93C5FD,stroke-width:1.5px,color:#1E293B,rx:6
    classDef decision fill:#FFFBEB,stroke:#FCD34D,stroke-width:1.5px,color:#92400E
    classDef highlight fill:#3B82F6,stroke:#3B82F6,stroke-width:1.5px,color:#FFFFFF,rx:6
    classDef success fill:#ECFDF5,stroke:#6EE7B7,stroke-width:1.5px,color:#065F46,rx:6
    classDef error fill:#FFF1F2,stroke:#FDA4AF,stroke-width:1.5px,color:#9F1239,rx:6

    style payment fill:#EFF6FF,stroke:#BFDBFE,stroke-width:1px,color:#1E40AF,rx:8
