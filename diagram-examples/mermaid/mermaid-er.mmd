---
title: 电商数据库 ER 模型
---
erDiagram
    USERS ||--o{ ORDERS : "下单"
    USERS ||--o{ ADDRESSES : "拥有收货地址"
    ORDERS ||--|{ ORDER_ITEMS : "包含商品明细"
    ORDERS ||--o| PAYMENTS : "关联支付"
    ORDERS }o--|| ADDRESSES : "使用收货地址"
    ORDER_ITEMS }o--|| PRODUCTS : "关联商品"
    PRODUCTS }o--|| CATEGORIES : "所属分类"
    CATEGORIES ||--o{ CATEGORIES : "父子分类"
    PAYMENTS }o--|| PAYMENT_CHANNELS : "使用支付渠道"

    USERS {
        bigint id PK "用户ID"
        varchar username UK "用户名"
        varchar email UK "邮箱"
        varchar phone "手机号"
        varchar password_hash "密码哈希"
        enum role "角色: customer/admin/merchant"
        timestamp created_at "创建时间"
        timestamp updated_at "更新时间"
        boolean is_active "是否启用"
    }

    ORDERS {
        bigint id PK "订单ID"
        varchar order_no UK "订单编号"
        bigint user_id FK "用户ID"
        bigint address_id FK "收货地址ID"
        enum status "订单状态"
        decimal total_amount "总金额"
        decimal discount_amount "优惠金额"
        decimal pay_amount "实付金额"
        varchar remark "订单备注"
        timestamp created_at "下单时间"
        timestamp paid_at "支付时间"
        timestamp shipped_at "发货时间"
        timestamp completed_at "完成时间"
    }

    ORDER_ITEMS {
        bigint id PK "明细ID"
        bigint order_id FK "订单ID"
        bigint product_id FK "商品ID"
        varchar product_name "商品名称快照"
        decimal unit_price "单价快照"
        int quantity "数量"
        decimal subtotal "小计金额"
    }

    PRODUCTS {
        bigint id PK "商品ID"
        varchar name "商品名称"
        text description "商品描述"
        decimal price "售价"
        decimal cost_price "成本价"
        int stock "库存数量"
        bigint category_id FK "分类ID"
        enum status "状态: on_sale/off_sale"
        varchar image_url "主图URL"
        timestamp created_at "创建时间"
    }

    CATEGORIES {
        bigint id PK "分类ID"
        varchar name "分类名称"
        bigint parent_id FK "父分类ID"
        int sort_order "排序权重"
        boolean is_active "是否启用"
    }

    ADDRESSES {
        bigint id PK "地址ID"
        bigint user_id FK "用户ID"
        varchar receiver_name "收件人"
        varchar phone "联系电话"
        varchar province "省"
        varchar city "市"
        varchar district "区"
        varchar detail "详细地址"
        boolean is_default "是否默认"
    }

    PAYMENTS {
        bigint id PK "支付ID"
        varchar payment_no UK "支付流水号"
        bigint order_id FK "订单ID"
        bigint channel_id FK "支付渠道ID"
        enum status "状态: pending/success/failed/refunded"
        decimal amount "支付金额"
        varchar transaction_id "第三方交易号"
        timestamp paid_at "支付时间"
        timestamp refunded_at "退款时间"
    }

    PAYMENT_CHANNELS {
        bigint id PK "渠道ID"
        varchar name "渠道名称"
        varchar code UK "渠道编码"
        boolean is_active "是否启用"
        json config "渠道配置"
    }
