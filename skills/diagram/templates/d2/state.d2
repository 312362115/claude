# 订单状态机

direction: right

# --- 初始状态 ---
initial: "" {
  shape: circle
  width: 24
  height: 24
  style: {
    fill: "#1E293B"
    stroke: "#1E293B"
  }
}

# --- 主流程状态（Blue）---
pending: 待支付 {
  style: {
    fill: "#EFF6FF"
    stroke: "#93C5FD"
    font-color: "#1E293B"
    border-radius: 6
    font-size: 13
  }
}

paid: 已支付 {
  style: {
    fill: "#EFF6FF"
    stroke: "#93C5FD"
    font-color: "#1E293B"
    border-radius: 6
    font-size: 13
  }
}

preparing: 备货中 {
  style: {
    fill: "#EFF6FF"
    stroke: "#93C5FD"
    font-color: "#1E293B"
    border-radius: 6
    font-size: 13
  }
}

shipped: 已发货 {
  style: {
    fill: "#EFF6FF"
    stroke: "#93C5FD"
    font-color: "#1E293B"
    border-radius: 6
    font-size: 13
  }
}

# --- 成功终态（Emerald）---
completed: 已完成 {
  style: {
    fill: "#ECFDF5"
    stroke: "#6EE7B7"
    font-color: "#065F46"
    border-radius: 6
    font-size: 13
  }
}

# --- 异常状态（Rose）---
cancelled: 已取消 {
  style: {
    fill: "#FFF1F2"
    stroke: "#FDA4AF"
    font-color: "#9F1239"
    border-radius: 6
    font-size: 13
  }
}

refunding: 退款中 {
  style: {
    fill: "#FFF1F2"
    stroke: "#FDA4AF"
    font-color: "#9F1239"
    border-radius: 6
    font-size: 13
  }
}

refunded: 已退款 {
  style: {
    fill: "#FFF1F2"
    stroke: "#FDA4AF"
    font-color: "#9F1239"
    border-radius: 6
    font-size: 13
  }
}

# --- 终止状态 ---
final: "" {
  shape: circle
  width: 28
  height: 28
  style: {
    fill: "#64748B"
    stroke: "#64748B"
  }
}

# ============ 状态转换 ============

# 主路径
initial -> pending: 创建订单 {
  style.stroke: "#94A3B8"
  style.font-color: "#64748B"
  style.font-size: 11
}
pending -> paid: 支付成功 {
  style.stroke: "#10B981"
  style.font-color: "#065F46"
  style.font-size: 11
}
paid -> preparing: 商家确认 {
  style.stroke: "#94A3B8"
  style.font-color: "#64748B"
  style.font-size: 11
}
preparing -> shipped: 发货 {
  style.stroke: "#94A3B8"
  style.font-color: "#64748B"
  style.font-size: 11
}
shipped -> completed: 签收确认 {
  style.stroke: "#10B981"
  style.font-color: "#065F46"
  style.font-size: 11
}

# 取消路径
pending -> cancelled: 超时/取消 {
  style.stroke: "#F43F5E"
  style.font-color: "#9F1239"
  style.font-size: 11
}

# 退款路径
paid -> refunding: 申请退款 {
  style.stroke: "#F43F5E"
  style.font-color: "#9F1239"
  style.font-size: 11
}
shipped -> refunding: 拒收退回 {
  style.stroke: "#F43F5E"
  style.font-color: "#9F1239"
  style.font-size: 11
}
refunding -> refunded: 退款通过 {
  style.stroke: "#94A3B8"
  style.font-color: "#64748B"
  style.font-size: 11
}

# 终止
completed -> final {
  style.stroke: "#94A3B8"
}
cancelled -> final {
  style.stroke: "#94A3B8"
}
refunded -> final {
  style.stroke: "#94A3B8"
}
