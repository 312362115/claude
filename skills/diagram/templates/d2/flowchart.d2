# 示例：订单处理流程

direction: down

# --- 开始 ---
start: 用户提交订单 {
  shape: oval
  style: {
    fill: "#ECFDF5"
    stroke: "#6EE7B7"
    font-color: "#065F46"
    border-radius: 20
    font-size: 13
  }
}

# --- 处理步骤 ---
validate: 订单参数校验 {
  style: {
    fill: "#EFF6FF"
    stroke: "#93C5FD"
    font-color: "#1E293B"
    border-radius: 6
    font-size: 13
  }
}

# --- 判断 ---
is-valid: 参数合法? {
  shape: diamond
  style: {
    fill: "#FFFBEB"
    stroke: "#FCD34D"
    font-color: "#92400E"
    font-size: 12
  }
}

check-stock: 库存检查 {
  style: {
    fill: "#EFF6FF"
    stroke: "#93C5FD"
    font-color: "#1E293B"
    border-radius: 6
    font-size: 13
  }
}

has-stock: 库存充足? {
  shape: diamond
  style: {
    fill: "#FFFBEB"
    stroke: "#FCD34D"
    font-color: "#92400E"
    font-size: 12
  }
}

lock-stock: 锁定库存 {
  style: {
    fill: "#EFF6FF"
    stroke: "#93C5FD"
    font-color: "#1E293B"
    border-radius: 6
    font-size: 13
  }
}

# --- 关键步骤 ---
create-order: 创建订单记录 {
  style: {
    fill: "#3B82F6"
    stroke: "#3B82F6"
    font-color: "#FFFFFF"
    border-radius: 6
    font-size: 13
    bold: true
    shadow: true
  }
}

# --- 子流程分组 ---
payment: 支付处理 {
  style: {
    fill: "#EFF6FF"
    stroke: "#BFDBFE"
    border-radius: 8
    font-color: "#1E40AF"
    font-size: 13
    bold: true
  }

  call-pay: 调用支付服务 {
    style: {
      fill: "#EFF6FF"
      stroke: "#93C5FD"
      font-color: "#1E293B"
      border-radius: 6
      font-size: 13
    }
  }

  pay-ok: 支付成功? {
    shape: diamond
    style: {
      fill: "#FFFBEB"
      stroke: "#FCD34D"
      font-color: "#92400E"
      font-size: 12
    }
  }

  call-pay -> pay-ok {
    style.stroke: "#94A3B8"
    style.stroke-width: 2
  }
}

# --- 成功 ---
confirm: 确认订单 {
  style: {
    fill: "#ECFDF5"
    stroke: "#6EE7B7"
    font-color: "#065F46"
    border-radius: 6
    font-size: 13
  }
}

notify: 发送订单通知 {
  style: {
    fill: "#EFF6FF"
    stroke: "#93C5FD"
    font-color: "#1E293B"
    border-radius: 6
    font-size: 13
  }
}

done: 订单完成 {
  shape: oval
  style: {
    fill: "#ECFDF5"
    stroke: "#6EE7B7"
    font-color: "#065F46"
    border-radius: 20
    font-size: 13
  }
}

# --- 错误终点 ---
err-invalid: 返回参数错误 {
  style: {
    fill: "#FFF1F2"
    stroke: "#FDA4AF"
    font-color: "#9F1239"
    border-radius: 6
    font-size: 13
  }
}

err-stock: 退回库存不足 {
  style: {
    fill: "#FFF1F2"
    stroke: "#FDA4AF"
    font-color: "#9F1239"
    border-radius: 6
    font-size: 13
  }
}

err-pay: 支付失败处理 {
  style: {
    fill: "#FFF1F2"
    stroke: "#FDA4AF"
    font-color: "#9F1239"
    border-radius: 6
    font-size: 13
  }
}

fail: 订单失败 {
  shape: oval
  style: {
    fill: "#F1F5F9"
    stroke: "#CBD5E1"
    font-color: "#64748B"
    border-radius: 20
    font-size: 13
  }
}

# ============ 连线 ============

# 主路径（向下）
start -> validate {
  style.stroke: "#94A3B8"
  style.stroke-width: 2
}
validate -> is-valid {
  style.stroke: "#94A3B8"
  style.stroke-width: 2
}
is-valid -> check-stock: 是 {
  style.stroke: "#10B981"
  style.stroke-width: 2
  style.font-color: "#10B981"
  style.font-size: 11
}
check-stock -> has-stock {
  style.stroke: "#94A3B8"
  style.stroke-width: 2
}
has-stock -> lock-stock: 是 {
  style.stroke: "#10B981"
  style.stroke-width: 2
  style.font-color: "#10B981"
  style.font-size: 11
}
lock-stock -> create-order {
  style.stroke: "#94A3B8"
  style.stroke-width: 2
}
create-order -> payment.call-pay {
  style.stroke: "#94A3B8"
  style.stroke-width: 2
}
payment.pay-ok -> confirm: 是 {
  style.stroke: "#10B981"
  style.stroke-width: 2
  style.font-color: "#10B981"
  style.font-size: 11
}
confirm -> notify {
  style.stroke: "#94A3B8"
  style.stroke-width: 2
}
notify -> done {
  style.stroke: "#10B981"
  style.stroke-width: 2
}

# 失败路径（向右）
is-valid -> err-invalid: 否 {
  style.stroke: "#F43F5E"
  style.stroke-width: 2
  style.font-color: "#F43F5E"
  style.font-size: 11
}
has-stock -> err-stock: 否 {
  style.stroke: "#F43F5E"
  style.stroke-width: 2
  style.font-color: "#F43F5E"
  style.font-size: 11
}
payment.pay-ok -> err-pay: 否 {
  style.stroke: "#F43F5E"
  style.stroke-width: 2
  style.font-color: "#F43F5E"
  style.font-size: 11
}

# 错误汇聚
err-invalid -> fail {
  style.stroke: "#CBD5E1"
  style.stroke-width: 1
  style.stroke-dash: 3
}
err-stock -> fail {
  style.stroke: "#CBD5E1"
  style.stroke-width: 1
  style.stroke-dash: 3
}
err-pay -> fail {
  style.stroke: "#CBD5E1"
  style.stroke-width: 1
  style.stroke-dash: 3
}
