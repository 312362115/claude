---
title: 订单状态机
---
stateDiagram-v2
    direction TB

    [*] --> 待支付 : 创建订单

    state 待支付 {
        [*] --> 等待用户支付
        等待用户支付 --> 支付处理中 : 发起支付
        支付处理中 --> 等待用户支付 : 支付失败，可重试
    }

    待支付 --> 已支付 : 支付成功
    待支付 --> 已取消 : 超时未支付 / 用户取消

    state 订单履约 {
        已支付 --> 备货中 : 仓库接单
        备货中 --> 已发货 : 发出快递
        已发货 --> 已签收 : 用户确认收货 / 系统自动签收
    }

    已签收 --> [*]

    state 退款流程 {
        退款中 --> 退款审核 : 提交退款申请
        退款审核 --> 已退款 : 审核通过，退款到账
        退款审核 --> 退款中 : 审核不通过，补充材料
    }

    已支付 --> 已取消 : 支付后取消（自动退款）
    已支付 --> 退款中 : 申请退款
    备货中 --> 退款中 : 申请退款
    已发货 --> 退款中 : 申请退货退款
    已签收 --> 退款中 : 申请售后退款

    已退款 --> [*]
    已取消 --> [*]

    note right of 待支付
        支付超时时间：30 分钟
        超时自动取消释放库存
    end note

    note right of 已签收
        签收后 7 天内
        可申请售后退款
    end note

    note left of 退款流程
        退款审核时间：1-3 个工作日
        退款到账时间：3-5 个工作日
    end note
