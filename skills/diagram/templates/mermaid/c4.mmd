---
title: 电商平台 C4 容器图
---
C4Context
    title 电商平台系统架构 — C4 容器图

    Person(customer, "顾客", "浏览商品、下单购买、查看物流")
    Person(admin, "管理员", "管理商品、处理订单、数据分析")

    Enterprise_Boundary(ecommerce, "电商平台") {

        System_Boundary(frontend, "前端应用层") {
            Container(webapp, "Web 商城", "React, Next.js", "PC/H5 端购物页面")
            Container(mobile, "移动端 App", "React Native", "iOS/Android 客户端")
            Container(admin_portal, "管理后台", "Vue 3, Vite", "商品管理、订单管理、数据看板")
        }

        System_Boundary(backend, "后端服务层") {
            Container(api_gateway, "API 网关", "Kong / Nginx", "路由转发、限流、鉴权")
            Container(user_service, "用户服务", "Java, Spring Boot", "注册登录、用户信息管理")
            Container(product_service, "商品服务", "Java, Spring Boot", "商品 CRUD、库存管理、分类管理")
            Container(order_service, "订单服务", "Java, Spring Boot", "订单创建、状态流转、履约管理")
            Container(payment_service, "支付服务", "Go, Gin", "支付对接、退款处理、对账")
            Container(notification_service, "通知服务", "Node.js", "短信、邮件、App 推送")
        }

        System_Boundary(data, "数据存储层") {
            ContainerDb(mysql, "MySQL 主库", "MySQL 8.0", "用户、订单、商品等核心数据")
            ContainerDb(redis, "Redis 缓存", "Redis 7.x", "会话缓存、热点数据、分布式锁")
            ContainerQueue(mq, "消息队列", "RocketMQ", "异步解耦：订单事件、库存扣减、通知触发")
            ContainerDb(es, "Elasticsearch", "ES 8.x", "商品全文搜索、日志检索")
            ContainerDb(oss, "对象存储", "MinIO / S3", "商品图片、用户头像等静态资源")
        }
    }

    System_Ext(payment_platform, "第三方支付平台", "支付宝、微信支付")
    System_Ext(logistics, "物流系统", "顺丰、圆通等物流服务商")
    System_Ext(sms, "短信平台", "阿里云短信、腾讯云短信")

    Rel(customer, webapp, "使用", "HTTPS")
    Rel(customer, mobile, "使用", "HTTPS")
    Rel(admin, admin_portal, "使用", "HTTPS")

    Rel(webapp, api_gateway, "调用", "REST / GraphQL")
    Rel(mobile, api_gateway, "调用", "REST / GraphQL")
    Rel(admin_portal, api_gateway, "调用", "REST")

    Rel(api_gateway, user_service, "路由", "gRPC")
    Rel(api_gateway, product_service, "路由", "gRPC")
    Rel(api_gateway, order_service, "路由", "gRPC")
    Rel(api_gateway, payment_service, "路由", "gRPC")

    Rel(order_service, mq, "发布订单事件", "异步")
    Rel(mq, notification_service, "消费通知事件", "异步")
    Rel(mq, product_service, "消费库存扣减事件", "异步")

    Rel(user_service, mysql, "读写", "JDBC")
    Rel(product_service, mysql, "读写", "JDBC")
    Rel(order_service, mysql, "读写", "JDBC")
    Rel(payment_service, mysql, "读写", "JDBC")

    Rel(user_service, redis, "缓存", "Redis Protocol")
    Rel(product_service, redis, "缓存", "Redis Protocol")
    Rel(product_service, es, "搜索索引", "REST")

    Rel(payment_service, payment_platform, "支付对接", "HTTPS")
    Rel(order_service, logistics, "物流查询", "HTTPS")
    Rel(notification_service, sms, "发送短信", "HTTPS")

    UpdateLayoutConfig($c4ShapeInRow="3", $c4BoundaryInRow="1")
