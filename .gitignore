# macOS
.DS_Store

# 敏感信息 - 可能包含 API key / token
config.json

# 会话记录 - 体积大且无需版本控制
projects/

# 运行时缓存与临时文件
cache/
backups/
session-env/
shell-snapshots/
telemetry/
history.jsonl

# Claude Code 本地配置（个人偏好，不入版本控制）
.claude/

# IDE 状态
ide/

# 插件 - 可重新安装
plugins/

# 技能评估工作区 - 测试产物，非核心配置
skills/*/workspace/
skills/*-workspace/
skills/*/tests/bridge-review/

# 定时任务运行时状态
scheduled-tasks/

# Claude Code 任务运行时状态
tasks/


plans/
!docs/plans/
.history
file-history
sessions/
paste-cache/

# 调试日志 - 运行时产物
debug/

# 统计缓存
stats-cache.json

# 子目录的 README（插件缓存等）
plugins/**/README.md

# 下载目录
downloads/

# 待办事项 - 运行时产物
todos/

# 使用数据 - 运行时产物
usage-data/
playwright-mcp
node_modules/
.playwright-mcp/
